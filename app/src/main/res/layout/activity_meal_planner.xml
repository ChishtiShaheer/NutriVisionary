<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER: THE BLUEPRINT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/meal_blueprint"
                android:textColor="@color/navyBlue"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- ACTIVE GOAL SELECTION -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/goalCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/iceBlue"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/mealStroke"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/active_goal_label"
                            android:textColor="@color/slateGray"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvSelectedGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/select_goal"
                            android:textColor="@color/navyBlue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangeGoal"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/change_goal"
                        android:textColor="@color/royalBlue"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- REMAINING CALORIES CHART -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardMaxElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="24dp">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/remainingKcalProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:progress="0"
                            app:indicatorColor="@color/royalBlue"
                            app:indicatorSize="100dp"
                            app:trackColor="@color/softBlueGradientStart"
                            app:trackThickness="10dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvRemainingKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/navyBlue"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/remaining_calories"
                                android:textColor="@color/slateGray"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/target_kcal_label"
                                android:textColor="@color/slateGray"
                                android:textSize="14sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnLockCalories"
                                style="@style/Widget.MaterialComponents.Button.Icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_alignParentEnd="true"
                                android:insetLeft="0dp"
                                android:insetTop="0dp"
                                android:insetRight="0dp"
                                android:insetBottom="0dp"
                                android:padding="0dp"
                                app:icon="@android:drawable/ic_partial_secure"
                                app:iconGravity="textStart"
                                app:iconPadding="0dp"
                                app:iconSize="18dp"
                                app:iconTint="@color/slateGray"
                                app:backgroundTint="@color/iceBlue"
                                app:cornerRadius="8dp"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/tvTargetKcalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2000 kcal"
                            android:textColor="@color/navyBlue"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/kcalSlider"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:value="2000"
                            android:valueFrom="500"
                            android:valueTo="10000"
                            android:stepSize="100"
                            app:thumbColor="@color/royalBlue"
                            app:trackColorActive="@color/royalBlue"
                            app:trackColorInactive="@color/softBlueGradientStart" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MEAL CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <!-- Breakfast -->
                <include
                    layout="@layout/item_meal_card"
                    android:id="@+id/cardBreakfast" />

                <!-- Lunch -->
                <include
                    layout="@layout/item_meal_card"
                    android:id="@+id/cardLunch" />

                <!-- Snacks -->
                <include
                    layout="@layout/item_meal_card"
                    android:id="@+id/cardSnacks" />

                <!-- Dinner -->
                <include
                    layout="@layout/item_meal_card"
                    android:id="@+id/cardDinner" />

            </LinearLayout>

            <!-- GENERATE SELF-DESIGNED MEAL BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateSelfPlan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:text="Finalize My Custom Plan"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/royalBlue"
                app:cornerRadius="30dp" />

            <!-- AI DIET GENERATOR (Magic Card) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/royalBlue"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/magic_card_gradient"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/magic_card_title"
                        android:textColor="@color/navyBlue"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/magic_card_desc"
                        android:textColor="@color/slateGray"
                        android:textSize="14sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:chipSpacingHorizontal="8dp">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_vegan"
                            app:chipBackgroundColor="@color/chip_background_color" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_keto"
                            app:chipBackgroundColor="@color/chip_background_color" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/chip_high_protein"
                            app:chipBackgroundColor="@color/chip_background_color" />
                    </com.google.android.material.chip.ChipGroup>

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:text="@string/generate_plan"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/royalBlue"
                        app:cornerRadius="30dp"
                        app:icon="@drawable/ic_ai"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconTint="@color/white" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
