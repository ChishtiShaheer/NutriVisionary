<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/offWhite">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/analytics_title"
                android:textColor="@color/navyBlue"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- SEGMENTED CONTROL (Toggle) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/toggleBackground"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:animateLayoutChanges="true"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_bar_pill"
                        android:backgroundTint="@color/royalBlue"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/week"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tabMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/month"
                        android:textColor="@color/slateGray" />

                    <TextView
                        android:id="@+id/tabYear"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/year"
                        android:textColor="@color/slateGray" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WEIGHT TREND CARD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/weight_trend"
                android:textColor="@color/navyBlue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/weightCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/glass_card_bg"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/currentWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/avg_weight"
                            android:textColor="@color/navyBlue"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/weightDiff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/currentWeight"
                            android:text="@string/weight_diff"
                            android:textColor="@color/trendPositive"
                            android:textSize="13sp" />
                    </RelativeLayout>

                    <View
                        android:id="@+id/weightChartPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/soft_chart_placeholder" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ADHERENCE HEATMAP SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/adherence_heatmap_title"
                android:textColor="@color/navyBlue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/cardStroke"
                app:strokeWidth="1.5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <GridLayout
                            android:id="@+id/heatmapGrid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:columnCount="13"
                            android:rowCount="8"
                            android:useDefaultMargins="false"
                            android:layout_gravity="center">
                            <!-- Programmatically populated in Activity for better performance and clean XML -->
                        </GridLayout>
                    </HorizontalScrollView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="end"
                        android:orientation="horizontal">
                        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/heatmap_empty" android:layout_gravity="center_vertical"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/legend_less" android:textSize="10sp" android:textColor="@color/slateGray" android:layout_marginStart="4dp" android:layout_marginEnd="12dp"/>
                        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/heatmap_partial" android:layout_gravity="center_vertical"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/legend_mid" android:textSize="10sp" android:textColor="@color/slateGray" android:layout_marginStart="4dp" android:layout_marginEnd="12dp"/>
                        <View android:layout_width="10dp" android:layout_height="10dp" android:background="@color/heatmap_hit" android:layout_gravity="center_vertical"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/legend_hit" android:textSize="10sp" android:textColor="@color/slateGray" android:layout_marginStart="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- HORIZONTAL QUICK STATS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Avg Calories Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/stat_card_gradient"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/avg_calories_label"
                                android:textColor="@color/slateGray"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/avgCaloriesValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/avg_calories_value"
                                android:textColor="@color/royalBlue"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Streak Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/stat_card_gradient"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/streak_label"
                                android:textColor="@color/slateGray"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/streakValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/streak_value"
                                android:textColor="@color/royalBlue"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Goal Progress Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/cardStroke"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/stat_card_gradient"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/goal_progress_label"
                                android:textColor="@color/slateGray"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/goalProgressValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/goal_progress_value"
                                android:textColor="@color/royalBlue"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
