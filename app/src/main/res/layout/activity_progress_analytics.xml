<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <!-- ── HEADER ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/navyBlue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="6dp"
                    android:layout_toEndOf="@id/btnBack"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/analytics_title"
                    android:textColor="@color/navyBlue"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ── PERIOD TOGGLE ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/toggleBackground"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/week"
                        android:textColor="@color/slateGray"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tabMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/month"
                        android:textColor="@color/slateGray"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tabYear"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/year"
                        android:textColor="@color/slateGray"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SECTION: ADHERENCE HEATMAP ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="@string/adherence_map_title"
                android:textColor="@color/navyBlue"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Heatmap grid inside horizontal scroll -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:fadingEdgeLength="16dp"
                        android:requiresFadingEdge="horizontal">

                        <GridLayout
                            android:id="@+id/heatmapGrid"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:rowCount="8"
                            android:useDefaultMargins="false" />
                    </HorizontalScrollView>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@color/heatmap_empty" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="10dp"
                            android:text="@string/legend_no_log"
                            android:textColor="@color/slateGray"
                            android:textSize="10sp" />

                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@color/heatmap_partial" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="10dp"
                            android:text="@string/legend_partial"
                            android:textColor="@color/slateGray"
                            android:textSize="10sp" />

                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@color/heatmap_hit" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="10dp"
                            android:text="@string/legend_hit"
                            android:textColor="@color/slateGray"
                            android:textSize="10sp" />

                        <View
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            android:background="@color/heatmap_over" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/legend_off_track"
                            android:textColor="@color/heatmap_over"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SECTION: SLEEP ANALYTICS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="@string/sleep_trend_title"
                android:textColor="@color/navyBlue"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvSleepStats"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Avg Sleep: 0 hrs"
                                android:textColor="@color/darkText"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvSleepWarning"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Goal consistently met!"
                                android:textColor="@color/macroProtein"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Sleep goal baseline hint -->
                    <TextView
                        android:id="@+id/tvSleepGoalLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Last 15 days  ·  goal line = 8 hrs"
                        android:textColor="@color/slateGray"
                        android:textSize="11sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutSleepCycles"
                            android:layout_width="wrap_content"
                            android:layout_height="130dp"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:paddingTop="8dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── STATS ROW 1: Weight & Avg Calories ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current_weight_label"
                            android:textSize="11sp"
                            android:textColor="@color/grayText"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/currentWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0.0 kg"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryBlue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/avg_calories_label"
                            android:textSize="11sp"
                            android:textColor="@color/grayText"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/avgCaloriesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 kcal"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primaryBlue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── STATS ROW 2: Streak & Progress ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/streak_label_stat"
                            android:textSize="11sp"
                            android:textColor="@color/grayText"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/streakValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 Days"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/royalBlue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/progress_label_stat"
                            android:textSize="11sp"
                            android:textColor="@color/grayText"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/goalProgressValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0%"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/royalBlue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>